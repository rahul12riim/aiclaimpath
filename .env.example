# ─── AI ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=ucmkey

# ─── EMBEDDINGS ───────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── VECTOR DB ────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=aiworkforce-knowledge

# ─── DATABASE (non-sensitive only) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Required Supabase table (run once in Supabase SQL editor):
# CREATE TABLE IF NOT EXISTS feedback (
#   id          UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#   name        TEXT NOT NULL,
#   email       TEXT NOT NULL,
#   department  TEXT NOT NULL,
#   message     TEXT NOT NULL,
#   created_at  TIMESTAMPTZ DEFAULT NOW()
# );
# ALTER TABLE feedback ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "service_role full access" ON feedback USING (true) WITH CHECK (true);

# ─── CACHE & RATE LIMITING ────────────────────────────────────────
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ─── APP ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://aiworkforce.com
NODE_ENV=development
